# --- App ---
PORT=3001
# Frontend origin allowed to call this API (CORS). Comma-separated for multiple.
FRONTEND_ORIGIN=https://foodezy.wedev.site

# --- Database (MySQL on Dokploy) ---
# On Dokploy (same project): use the INTERNAL host + port 3306
# For local testing: use the server IP/ddns + the EXTERNAL port
DB_HOST=foodezy-db-me2kxd
DB_PORT=3306
DB_USER=foodezy_user
DB_PASSWORD=change_me
DB_NAME=foodezy

# --- Uploads ---
# Folder where shop images are saved. On Dokploy this path is a mounted Volume.
UPLOAD_DIR=/app/uploads
# Public base path the images are served under
UPLOAD_URL_PREFIX=/uploads
# Max upload size per image in bytes (5 MB)
MAX_UPLOAD_BYTES=5242880

# --- Admin auth ---
# Secret used to sign the admin login token. Use a long random string.
JWT_SECRET=change_me_to_a_long_random_string
# Parent domain so the cookie set by the API is also sent by the site host.
COOKIE_DOMAIN=foodezy.wedev.site
# Set to false only when testing over plain http locally.
COOKIE_SECURE=true
